# ticket-loop Telegram bridge — copy these two lines into your repo-root .env
# (telegram.py reads the environment first, then falls back to <repo>/.env)

# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=123456789:AAabcdefghijklmnopqrstuvwxyz

# The dedicated group's chat id — get it with:
#   python3 .claude/skills/ticket-loop/telegram.py discover
# (group ids are negative, supergroups start with -100)
AGENT_TELEGRAM_CHAT_ID=-1001234567890

# ── Runner env (optional) ─────────────────────────────────────────────────────
# These configure the headless runner (cron-run.sh / the container). In the
# containerized deployment the systemd unit + run-pass.sh set them for you; set
# them here only for a custom laptop layout. Most repo-specific values (model,
# base branch, timezone, state dir) are better placed in dev-workflow.yml — these
# env vars override that config when present.
#
# DW_WORK_TREE=/path/to/target-repo    # the checkout the loop drives (REQUIRED in
#                                      #   the container; defaults to the repo
#                                      #   containing cron-run.sh on a laptop)
# DW_PLUGIN_DIR=/opt/dev-workflow/plugin  # if set AND `claude` supports --plugin-dir,
#                                      #   the runner loads the baked plugin and
#                                      #   invokes /dev-workflow:ticket-loop
# DW_SKILL_INVOCATION=/ticket-loop     # override the skill the runner invokes
# DW_ENV_FILE=/home/agent/agent.env    # run-pass.sh sources this for secrets
# TICKET_LOOP_STATE_DIR=.agent-loop    # where state.json/lock/media live (absolute,
#                                      #   or relative to the work tree; default
#                                      #   .agent-loop, or runtime.state_dir in config)
# TICKET_LOOP_MODEL=sonnet             # pin the model the pass runs on (else build.model)
# TICKET_LOOP_MCP_CONFIG=/opt/dev-workflow/loop-mcp.json  # keyed tracker MCP (no OAuth)
# TICKET_LOOP_TZ=America/New_York      # the loop's "new day" zone (else schedule.tz)
